<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MyGuardianWatch" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
    </style>

    <!-- Squircle launcher icon: IconBackground draws the white circle behind it. -->
    <style name="MainActivityTheme.Starting" parent="Theme.SplashScreen.IconBackground">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.MyGuardianWatch</item>
    </style>
</resources>
